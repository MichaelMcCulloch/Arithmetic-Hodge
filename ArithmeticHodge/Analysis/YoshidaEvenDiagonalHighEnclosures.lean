/-!
# Scalable high-mode diagonal enclosures

This module pilots the high-mode diagonal certificates at mode `190`.  It
uses the fine common accelerated base, the higher-order analytic tail at
`N = 16384`, and outward-rounded 16-term finite-head checkpoints.  No finite
truncation is substituted for the actual infinite moment.

The generic checkpoint combinators are public so subsequent high-mode band
modules can reuse the memory-bounded proof architecture without copying it.
-/

/-- Full higher-order series enclosure using the fine common base. -/
def fineDiagonalHigherSeriesInterval (n N : ℕ) : RatInterval :=
  fineDiagonalBaseInterval n - diagonalHeadInterval n (N - 1) -
    diagonalHigherTailInterval n N

/-- Coarse-head variant of `fineDiagonalHigherSeriesInterval`. -/
def fineDiagonalHigherCoarseSeriesInterval
    (n N : ℕ) (coarseHead : RatInterval) : RatInterval :=
  fineDiagonalBaseInterval n - coarseHead - diagonalHigherTailInterval n N

/-- The fine higher-order series interval contains the actual production
diagonal moment under the analytic cutoff hypotheses. -/
theorem fineDiagonalHigherSeriesInterval_contains
    {n N : ℕ} (hn : n ≠ 0) (hN : 16 ≤ N) (hmode : 10 * n ≤ N) :
    (fineDiagonalHigherSeriesInterval n N).Contains
      (yoshidaDiagonalMoment n) := by
  rw [yoshidaDiagonalMoment_eq_acceleratedSeries hn]
  rw [← diagonalCorrection_head_add_tail_eq_tsum
    (n := n) (N := N) hn (by omega)]
  have hbase := fineDiagonalBaseInterval_contains_acceleratedBase n
  have hhead := diagonalHeadInterval_contains n (N - 1)
  have htail := diagonalHigherTailInterval_contains hN hmode
  unfold fineDiagonalHigherSeriesInterval
  have hcombine := contains_sub (contains_sub hbase hhead) htail
  convert hcombine using 1
  ring

theorem isSubinterval_sub_same_right
    {I I' : RatInterval} (hI : IsSubinterval I I') (J : RatInterval) :
    IsSubinterval (I - J) (I' - J) := by
  change I'.lower - J.upper ≤ I.lower - J.upper ∧
    I.upper - J.lower ≤ I'.upper - J.lower
  exact ⟨sub_le_sub_right hI.1 _, sub_le_sub_right hI.2 _⟩

theorem fineDiagonalHigherSeriesInterval_sub_coarse
    {n N : ℕ} {coarseHead : RatInterval}
    (hhead : IsSubinterval (diagonalHeadInterval n (N - 1)) coarseHead) :
    IsSubinterval (fineDiagonalHigherSeriesInterval n N)
      (fineDiagonalHigherCoarseSeriesInterval n N coarseHead) := by
  exact isSubinterval_sub_same_right
    (isSubinterval_sub_right (fineDiagonalBaseInterval n) hhead)
    (diagonalHigherTailInterval n N)

/-! Sixteen-term checkpoints bound kernel reduction.  The last block has
15 terms, so `chunks` blocks cover exactly `k = 1, ..., 16 * chunks - 1`. -/

def smallScheduledChunkLength (total i : ℕ) : ℕ :=
  if i + 1 = total then 15 else 16

def smallScheduledChunkInterval (n total i : ℕ) : RatInterval :=
  diagonalChunkInterval n (1 + 16 * i) (smallScheduledChunkLength total i)

def smallExactCheckpointHead (n total : ℕ) : ℕ → RatInterval
  | 0 => pure 0
  | used + 1 =>
      smallExactCheckpointHead n total used +
        smallScheduledChunkInterval n total used

theorem smallExactCheckpointHead_eq_regular
    (n total used : ℕ) (hused : used < total) :
    smallExactCheckpointHead n total used =
      diagonalHeadIntervalAux n (16 * used) 1 (pure 0) := by
  induction used with
  | zero => rfl
  | succ used ih =>
      rw [smallExactCheckpointHead, ih (by omega)]
      unfold smallScheduledChunkInterval smallScheduledChunkLength
      rw [if_neg (by omega)]
      rw [show 16 * (used + 1) = 16 * used + 16 by omega]
      rw [diagonalHeadIntervalAux_add]
      rw [diagonalHeadIntervalAux_acc n 16 (1 + 16 * used)
        (diagonalHeadIntervalAux n (16 * used) 1 (pure 0))]
      simp only [diagonalChunkInterval]

theorem smallExactCheckpointHead_eq_diagonalHead
    (n chunks : ℕ) (hchunks : 0 < chunks) :
    smallExactCheckpointHead n chunks chunks =
      diagonalHeadInterval n (16 * chunks - 1) := by
  cases chunks with
  | zero => omega
  | succ chunks =>
      rw [smallExactCheckpointHead]
      rw [smallExactCheckpointHead_eq_regular n (chunks + 1) chunks (by omega)]
      unfold smallScheduledChunkInterval smallScheduledChunkLength
      rw [if_pos rfl]
      rw [diagonalHeadInterval,
        show 16 * (chunks + 1) - 1 = 16 * chunks + 15 by omega]
      rw [diagonalHeadIntervalAux_add]
      rw [diagonalHeadIntervalAux_acc n 15 (1 + 16 * chunks)
        (diagonalHeadIntervalAux n (16 * chunks) 1 (pure 0))]
      simp only [diagonalChunkInterval]

theorem smallCheckpointHead_subinterval
    (n chunks : ℕ) (box : ℕ → RatInterval)
    (hcert : ∀ i, i < chunks →
      IsSubinterval (smallScheduledChunkInterval n chunks i) (box i)) :
    IsSubinterval (smallExactCheckpointHead n chunks chunks)
      (coarseCheckpointHead box chunks) := by
  have hprefix : ∀ used, used ≤ chunks →
      IsSubinterval (smallExactCheckpointHead n chunks used)
        (coarseCheckpointHead box used) := by
    intro used hused
    induction used with
    | zero => exact isSubinterval_refl _
    | succ used ih =>
        rw [smallExactCheckpointHead, coarseCheckpointHead]
        exact isSubinterval_add (ih (by omega)) (hcert used (by omega))
  exact hprefix chunks le_rfl

theorem diagonalHeadInterval_sub_smallCheckpoint
    (n chunks : ℕ) (hchunks : 0 < chunks) (box : ℕ → RatInterval)
    (hcert : ∀ i, i < chunks →
      IsSubinterval (smallScheduledChunkInterval n chunks i) (box i)) :
    IsSubinterval (diagonalHeadInterval n (16 * chunks - 1))
      (coarseCheckpointHead box chunks) := by
  rw [← smallExactCheckpointHead_eq_diagonalHead n chunks hchunks]
  exact smallCheckpointHead_subinterval n chunks box hcert

def intervalSlice
    (box : ℕ → RatInterval) (start : ℕ) : ℕ → RatInterval
  | 0 => pure 0
  | used + 1 => intervalSlice box start used + box (start + used)

theorem intervalSlice_add
    (box : ℕ → RatInterval) (start a b : ℕ) :
    intervalSlice box start (a + b) =
      intervalSlice box start a + intervalSlice box (start + a) b := by
  induction b with
  | zero => simp [intervalSlice, add_pure_zero]
  | succ b ih =>
      rw [Nat.add_succ, intervalSlice, ih, intervalSlice, interval_add_assoc]
      simp only [Nat.add_assoc]

theorem coarseCheckpointHead_eq_intervalSlice
    (box : ℕ → RatInterval) (used : ℕ) :
    coarseCheckpointHead box used = intervalSlice box 0 used := by
  induction used with
  | zero => rfl
  | succ used ih =>
      simp only [coarseCheckpointHead, intervalSlice, ih, Nat.zero_add]

theorem coarseCheckpointHead_eq_octets
    (box : ℕ → RatInterval) (groups : ℕ) :
    coarseCheckpointHead box (8 * groups) =
      coarseCheckpointHead (fun g ↦ intervalSlice box (8 * g) 8) groups := by
  induction groups with
  | zero => rfl
  | succ groups ih =>
      calc
        coarseCheckpointHead box (8 * (groups + 1)) =
            intervalSlice box 0 (8 * (groups + 1)) :=
          coarseCheckpointHead_eq_intervalSlice _ _
        _ = intervalSlice box 0 (8 * groups + 8) := by
          congr 1
        _ = intervalSlice box 0 (8 * groups) +
            intervalSlice box (8 * groups) 8 := by
          simpa using intervalSlice_add box 0 (8 * groups) 8
        _ = coarseCheckpointHead box (8 * groups) +
            intervalSlice box (8 * groups) 8 := by
          rw [coarseCheckpointHead_eq_intervalSlice]
        _ = coarseCheckpointHead
              (fun g ↦ intervalSlice box (8 * g) 8) groups +
            intervalSlice box (8 * groups) 8 := by rw [ih]
        _ = coarseCheckpointHead
              (fun g ↦ intervalSlice box (8 * g) 8) (groups + 1) := by
          rw [coarseCheckpointHead]

theorem coarseCheckpointHead_subinterval
    (box box' : ℕ → RatInterval) (used : ℕ)
    (hcert : ∀ i, i < used → IsSubinterval (box i) (box' i)) :
    IsSubinterval (coarseCheckpointHead box used)
      (coarseCheckpointHead box' used) := by
  induction used with
  | zero => exact isSubinterval_refl _
  | succ used ih =>
      rw [coarseCheckpointHead, coarseCheckpointHead]
      exact isSubinterval_add
        (ih (fun i hi ↦ hcert i (by omega))) (hcert used (by omega))

