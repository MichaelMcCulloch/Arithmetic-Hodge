def YoshidaEvenSineTargetEnclosures : Prop :=
  ∀ n, 1 ≤ n → n ≤ 199 →
    (yoshidaEvenSineTargets n).Contains (yoshidaSineMoment n)

def YoshidaEvenDiagonalTargetEnclosures : Prop :=
  ∀ n, n ≤ 199 →
    (yoshidaEvenDiagonalTargets n).Contains (yoshidaDiagonalMoment n)

def YoshidaEvenFullTargetPivots : Prop :=
  PositivePivots evenPivotOrder
    (inflatedEvenMomentIntervalGram evenCorrectionRadius
      yoshidaEvenSineTargets yoshidaEvenDiagonalTargets)

